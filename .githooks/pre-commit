#!/usr/bin/env bash
# pre-commit: keep the vendored video-engine copies in sync with packages/video-engine.
# Re-vendors all video-* skills and stages the result, so a change to the engine source
# can never be committed without its synced copies. Enable once with:
#   git config core.hooksPath .githooks
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
[ -f "$ROOT/tools/sync-engine.sh" ] || exit 0

# Only vendor when THIS commit actually touches the engine source or its vendored copies.
# A commit that stages nothing under packages/video-engine or plugins/agency-os-video must
# not drag in unrelated (possibly uncommitted) video changes via the sync.
if ! git diff --cached --name-only \
  | grep -qE '^(packages/video-engine/|plugins/agency-os-video/)'; then
  exit 0
fi

bash "$ROOT/tools/sync-engine.sh" >/dev/null
git add "$ROOT/plugins/agency-os-video/skills"
